# ============================================================
# REQUIRED BY CODE — used by Foundry scripts and Hyperlane CLI
# ============================================================

# Deployer private key — used by `hyperlane warp deploy` (via HYP_KEY env)
# and `forge script --private-key $HYP_KEY`. Same key for both.
HYP_KEY=

# RPC endpoints — used by foundry.toml [rpc_endpoints] and CLI
ETH_RPC_URL=
BSC_RPC_URL=

# Block explorer API keys — used by foundry.toml [etherscan] for contract verification
ETHERSCAN_API_KEY=
BSCSCAN_API_KEY=

# Old BSC ON token — used by DeploySwap.s.sol (constructor arg for ONSwap)
# Source: https://github.com/orochi-network/on/blob/main/deployed/deployed.ts
OLD_ON_TOKEN_BSC=0x0e4F6209eD984b21EDEA43acE6e09559eD051D48

# New synthetic ON on BSC — used by DeploySwap.s.sol (constructor arg + seed transfer)
# Source: output of `hyperlane warp deploy` (Phase 2)
NEW_ON_TOKEN_BSC=

# ONSwap owner — used by DeploySwap.s.sol (constructor arg)
# Source: Gnosis Safe address on BSC
SWAP_OWNER=0xDA5E5Be8f9C5fCdd30f2ee08D6b3F794511C2B48

# Seed amount in wei — used by DeploySwap.s.sol (optional, default 100M * 1e18)
# Source: must match old BSC ON totalSupply()
SEED_AMOUNT=100000000000000000000000000

# ============================================================
# OPERATOR REFERENCE — used in GUIDE.md / CHECKLIST.md commands
# ============================================================

# Canonical ON on Ethereum — used in cast calls for monitoring
# Source: https://github.com/orochi-network/on/blob/main/deployed/deployed.ts
ON_TOKEN_ETHEREUM=0x33f6BE84becfF45ea6aA2952d7eF890B44bFB59d

# HypERC20Collateral on Ethereum — used in cast calls for collateral balance checks
# Source: output of `hyperlane warp deploy` (Phase 2)
COLLATERAL_CONTRACT=

# Warp route ID — used with `-w` flag in all hyperlane CLI commands
# Source: output of `hyperlane warp deploy` or `hyperlane warp read` (Phase 2)
WARP_ROUTE_ID=

# ONSwap contract on BSC — used in cast calls for swap monitoring
# Source: output of `forge script DeploySwap.s.sol` (Phase 3)
SWAP_CONTRACT=

# Deployer address — used in cast calls to verify 100M minted
# Source: derived from HYP_KEY (`cast wallet address --private-key $HYP_KEY`)
DEPLOYER_ADDRESS=

# Agent addresses — used in cast calls for balance monitoring and refunding
# Source: derived from AWS KMS public keys (Phase 1)
RELAYER_ADDRESS=
VALIDATOR_ADDRESS=
