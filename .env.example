# ── RPC endpoints ─────────────────────────────────────────────────────────────────
# JSON-RPC endpoints per chain. Real values often embed a provider API key, so treat them
# as secret. The public defaults below are valid and let the suite run; fork tests
# self-skip when ETH_RPC/BSC_RPC are unset.

# Ethereum mainnet RPC.
# [ ] build [x] runtime [x] optional [x] secret
ETH_RPC=https://eth.llamarpc.com

# Sepolia testnet RPC.
# [ ] build [x] runtime [x] optional [x] secret
SEPOLIA_RPC=https://ethereum-sepolia.publicnode.com

# BSC mainnet RPC.
# [ ] build [x] runtime [x] optional [x] secret
BSC_RPC=https://bsc-dataseed.binance.org

# BSC testnet RPC.
# [ ] build [x] runtime [x] optional [x] secret
BSC_TESTNET_RPC=https://data-seed-prebsc-1-s1.binance.org:8545

# ── Deployer ────────────────────────────────────────────────────────────────────────
# Signing is via a Foundry encrypted keystore account, NOT a raw key in .env. There is
# intentionally no DEPLOYER_PRIVATE_KEY variable. Create the account once (you'll be
# prompted for the key + a password), then deploy targets sign with `--account deployer`
# (override with ACCOUNT=<name>):
#   cast wallet import deployer --interactive

# ── Operations multisig ─────────────────────────────────────────────────────────────
# Operations multisig (Gnosis Safe). Required for `make handoff`, `make handoff-all`, and
# `make renounce`. Leave the zero placeholder until the actual Safe address is known —
# the Makefile target's `test -n` guard does NOT validate it is non-zero, but
# `script/06_TransferOwnership.s.sol` does. SECURITY: OPS-9.
# [ ] build [x] runtime [x] optional [ ] secret
MULTISIG=0x0000000000000000000000000000000000000000

# ── Block explorers (for forge verify) ──────────────────────────────────────────────
# Block-explorer API keys for `forge verify`. Only needed to verify source post-deploy.

# Etherscan API key.
# [ ] build [x] runtime [x] optional [x] secret
ETHERSCAN_API_KEY=

# BscScan API key.
# [ ] build [x] runtime [x] optional [x] secret
BSCSCAN_API_KEY=

# ── Optional ─────────────────────────────────────────────────────────────────────────
# Fork-test block pinning (SECURITY: TEST-1). When unset, test/fork/* tests use the
# defaults baked into the Solidity setUp() (currently ETH=22_000_000, BSC=50_000_000).
# Override to verify against a fresher state without editing source.
# [ ] build [x] runtime [x] optional [ ] secret
# ETH_FORK_BLOCK=22000000
# [ ] build [x] runtime [x] optional [ ] secret
# BSC_FORK_BLOCK=50000000

# Post-handoff `make update-limits` caller (SECURITY: OPS-2). Once the multisig owns the
# pool and the deployer EOA is no longer authorised, set CALLER_FLAGS to a Foundry
# credential that IS authorised (e.g. an encrypted keystore for the delegated
# `rateLimitAdmin`). Pre-handoff, leave unset and the target falls back to the keystore
# account (`--account deployer`).
# OPS-16: CALLER_FLAGS expands unquoted into the Makefile recipe — keep the value strictly
# `--account <name>` or `--keystore <path>`. Do NOT embed shell metacharacters; a tampered
# `.env` containing e.g. `--account x; rm -rf deployments/` would execute on broadcast.
# [ ] build [x] runtime [x] optional [ ] secret
# CALLER_FLAGS=--account ratelimit-admin

# Required by `make verify-eth` / `make verify-bsc` when MULTISIG is set, so the
# post-handoff renounce check has the deployer EOA to compare against (DEP-8). Set to the
# checksummed deployer address — NOT the private key. Cross-validated against the
# `deployer` field written into `deployments/<chainId>.json` by script 01 (DEP-11).
# [ ] build [x] runtime [x] optional [ ] secret
# DEPLOYER=0x0000000000000000000000000000000000000000

# Rate-limit flags. Defaults: enabled buckets, strict verify (OPS-15 / CCIP-10).
# Foundry's bool parser accepts ONLY the literal strings `true` / `false` (case-
# insensitive); `0` / `1` / `yes` will revert deep inside the cheatcode (DEP-16).
# [ ] build [x] runtime [x] optional [ ] secret
# OUTBOUND_ENABLED=true
# [ ] build [x] runtime [x] optional [ ] secret
# INBOUND_ENABLED=true
# [ ] build [x] runtime [x] optional [ ] secret
# STRICT_RATE_LIMITS=true
